{
  "name": "debatr",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Private AI-assisted structured debate platform",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @debatr/api db:generate",
    "db:migrate": "pnpm --filter @debatr/api db:migrate",
    "db:push": "pnpm --filter @debatr/api db:push",
    "db:studio": "pnpm --filter @debatr/api db:studio"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2"
  }
}

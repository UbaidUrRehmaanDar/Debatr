# ===========================================
# Debatr Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# Never commit .env with real secrets to Git.
# ===========================================

# -------------------------------------------
# Database (Neon PostgreSQL)
# -------------------------------------------
# Format: postgresql://user:password@host:port/database?sslmode=require
# Use separate branches for development and production.
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/debatr?sslmode=require"

# -------------------------------------------
# Better Auth Configuration
# -------------------------------------------
# Generate a random 32+ character string for production.
# Example: openssl rand -hex 32
BETTER_AUTH_SECRET="your-auth-secret-key-minimum-32-characters"

# Base URL for Better Auth endpoints (no trailing slash)
# Development: http://localhost:3000
# Production: https://api.yourdomain.com
BETTER_AUTH_URL="http://localhost:3000"

# -------------------------------------------
# Application Origins
# -------------------------------------------
# Frontend origin for CORS and CSRF protection (no trailing slash)
# Development: http://localhost:5173
# Production: https://yourdomain.com
WEB_ORIGIN="http://localhost:5173"

# Backend API origin (no trailing slash)
# Development: http://localhost:3000
# Production: https://api.yourdomain.com
API_ORIGIN="http://localhost:3000"

# -------------------------------------------
# OpenCode Zen AI Provider
# -------------------------------------------
# Obtain from https://opencode.ai or your provider dashboard
OPENCODE_API_KEY="sk-your-opencode-api-key"

# OpenCode Zen API base URL (no trailing slash)
OPENCODE_BASE_URL="https://api.opencode.ai/v1"

# Model identifiers for each role
# Lawyer: fast, inexpensive model for real-time assistance
AI_LAWYER_MODEL="opencode/fast-model"

# Judge: stronger reasoning model for post-debate evaluation
AI_JUDGE_MODEL="opencode/reasoning-model"

# -------------------------------------------
# AI Usage Limits and Timeouts
# -------------------------------------------
# Maximum tokens per single AI request
AI_MAX_TOKENS_PER_REQUEST="4096"

# Maximum tokens per debate (all AI calls combined)
AI_MAX_TOKENS_PER_DEBATE="50000"

# Timeout for AI requests in milliseconds (30 seconds default)
AI_REQUEST_TIMEOUT_MS="30000"

# Maximum retry attempts for failed AI requests
AI_MAX_RETRIES="3"

# -------------------------------------------
# Debate Settings (Defaults)
# -------------------------------------------
# These are snapshotted into each debate at creation.
# Changing these does not affect existing debates.

# Number of rounds per debate
DEBATE_DEFAULT_ROUNDS="4"

# Time per turn in minutes
DEBATE_DEFAULT_TURN_MINUTES="5"

# Maximum characters per public message
DEBATE_DEFAULT_MAX_CHARACTERS="2000"

# -------------------------------------------
# Environment
# -------------------------------------------
# development | production
NODE_ENV="development"

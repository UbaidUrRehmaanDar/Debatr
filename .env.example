# =============================================================================
# Debatr Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git - it is ignored by .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development

# Web frontend origin (no trailing slash)
WEB_ORIGIN=http://localhost:5173

# API backend origin (no trailing slash)
API_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# Format: postgresql://user:password@host:port/database?sslmode=require
# Use separate branches for development and production
DATABASE_URL=postgresql://user:password@host.neon.tech/debatr_dev?sslmode=require

# -----------------------------------------------------------------------------
# Authentication (Better Auth)
# -----------------------------------------------------------------------------
# Generate a random 32+ character string for production
# Example: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-change-in-production

# Better Auth base URL (should match API_ORIGIN)
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# AI Provider (OpenCode Zen)
# -----------------------------------------------------------------------------
# Get your API key from https://opencode.ai
OPENCODE_API_KEY=sk-your-api-key-here

# OpenCode Zen API base URL
OPENCODE_BASE_URL=https://api.opencode.ai/v1

# Model for Lawyer role (fast, cheap, instruction-following)
# To be confirmed after local evaluation
AI_LAWYER_MODEL=opencode/fast-model

# Model for Judge role (strong reasoning)
# To be confirmed after local evaluation
AI_JUDGE_MODEL=opencode/reasoning-model

# -----------------------------------------------------------------------------
# AI Controls (optional - defaults shown)
# -----------------------------------------------------------------------------
# Maximum tokens per individual AI request
AI_MAX_TOKENS_PER_REQUEST=4096

# Maximum total tokens per debate (all AI calls combined)
AI_MAX_TOKENS_PER_DEBATE=50000

# Timeout for AI requests in milliseconds
AI_REQUEST_TIMEOUT_MS=30000

# Maximum retry attempts for failed AI requests
AI_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Debate Defaults (optional - defaults shown)
# -----------------------------------------------------------------------------
# Number of rounds per debate
DEBATE_DEFAULT_ROUNDS=4

# Time limit per turn in minutes
DEBATE_DEFAULT_TURN_MINUTES=5

# Maximum characters per public message
DEBATE_DEFAULT_MESSAGE_MAX_CHARS=2000

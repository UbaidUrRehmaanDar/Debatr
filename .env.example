# Debatr environment template (safe placeholders only — never commit real values)
# Copy to `.env` locally and fill with real secrets from a secure secret store.
# All values below are server-side unless marked PUBLIC_; never expose secrets to the browser.

# ---- Application ----
NODE_ENV=development
# Public base URL of the SvelteKit web app (safe to expose to the browser)
WEB_ORIGIN=http://localhost:5173
# Base URL of the Fastify API
API_ORIGIN=http://localhost:3000

# ---- Database (Neon PostgreSQL via Drizzle ORM) ----
# Server-side only. Format: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/debatr?sslmode=require

# ---- Authentication (Better Auth) ----
# Server-side only. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
# Base URL Better Auth uses for callbacks (usually the API origin)
BETTER_AUTH_URL=http://localhost:3000

# ---- AI provider (OpenCode Zen, direct — no OpenRouter) ----
# Server-side only.
OPENCODE_API_KEY=replace-with-your-opencode-api-key
OPENCODE_BASE_URL=https://api.opencode.ai/v1
# Model IDs are intentionally left empty until a non-production evaluation
# confirms structured-JSON reliability, context capacity, prompt adherence,
# and acceptable privacy/retention terms. Do not use a free model whose terms
# allow private debate data to be retained or used for training/improvement.
AI_LAWYER_MODEL=
AI_JUDGE_MODEL=

# ---- AI controls (server-side, validated at startup) ----
# Maximum tokens per single AI request
AI_MAX_TOKENS_PER_REQUEST=4096
# Maximum tokens per debate (all AI calls combined)
AI_MAX_TOKENS_PER_DEBATE=50000
# Request timeout in milliseconds
AI_REQUEST_TIMEOUT_MS=60000
# Number of retry attempts on transient failure
AI_MAX_RETRIES=3

# ---- Debate defaults (snapshotted into each debate at creation) ----
DEBATE_DEFAULT_ROUNDS=4
DEBATE_DEFAULT_TURN_MINUTES=5
DEBATE_DEFAULT_MAX_CHARACTERS=2000

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://debatr.app/schemas/judge-response.schema.json",
  "title": "JudgeResponse",
  "description": "Structured neutral evaluation of a completed, locked public debate transcript.",
  "type": "object",
  "additionalProperties": false,
  "required": ["outcome", "confidence", "verdict", "scores", "strengths", "weaknesses", "feedback", "fallacies", "conductFindings", "summary"],
  "properties": {
    "outcome": { "type": "string", "enum": ["affirmative", "negative", "draw", "inconclusive"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "verdict": { "type": "string", "minLength": 1, "maxLength": 4000 },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["affirmative", "negative"],
      "properties": { "affirmative": { "$ref": "#/$defs/ScoreBreakdown" }, "negative": { "$ref": "#/$defs/ScoreBreakdown" } }
    },
    "strengths": { "$ref": "#/$defs/SideList" },
    "weaknesses": { "$ref": "#/$defs/SideList" },
    "feedback": { "$ref": "#/$defs/SideText" },
    "fallacies": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["side", "label", "explanation", "messageIds"],
        "properties": {
          "side": { "type": "string", "enum": ["affirmative", "negative"] },
          "label": { "type": "string", "maxLength": 120 },
          "explanation": { "type": "string", "maxLength": 1000 },
          "messageIds": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "type": "string", "format": "uuid" } }
        }
      }
    },
    "conductFindings": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["side", "category", "recommendedAction", "explanation", "messageIds"],
        "properties": {
          "side": { "type": "string", "enum": ["affirmative", "negative"] },
          "category": { "type": "string", "enum": ["harassment", "threat", "hate", "spam", "disruption", "other"] },
          "recommendedAction": { "type": "string", "enum": ["none", "warning", "official_warning", "penalty", "terminate"] },
          "explanation": { "type": "string", "maxLength": 1000 },
          "messageIds": { "type": "array", "minItems": 1, "maxItems": 5, "items": { "type": "string", "format": "uuid" } }
        }
      }
    },
    "summary": { "type": "string", "minLength": 1, "maxLength": 2400 }
  },
  "$defs": {
    "ScoreBreakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logicalConsistency", "evidenceQuality", "rebuttalEffectiveness", "argumentStructure", "responsiveness"],
      "properties": {
        "logicalConsistency": { "$ref": "#/$defs/Score" },
        "evidenceQuality": { "$ref": "#/$defs/Score" },
        "rebuttalEffectiveness": { "$ref": "#/$defs/Score" },
        "argumentStructure": { "$ref": "#/$defs/Score" },
        "responsiveness": { "$ref": "#/$defs/Score" }
      }
    },
    "Score": { "type": "number", "minimum": 0, "maximum": 100 },
    "SideList": {
      "type": "object", "additionalProperties": false, "required": ["affirmative", "negative"],
      "properties": {
        "affirmative": { "type": "array", "maxItems": 5, "items": { "type": "string", "maxLength": 800 } },
        "negative": { "type": "array", "maxItems": 5, "items": { "type": "string", "maxLength": 800 } }
      }
    },
    "SideText": {
      "type": "object", "additionalProperties": false, "required": ["affirmative", "negative"],
      "properties": { "affirmative": { "type": "string", "maxLength": 1600 }, "negative": { "type": "string", "maxLength": 1600 } }
    }
  }
}
